# =============================================================================
# .env.example — Template for Local Development Environment
# =============================================================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# The .env file is intentionally excluded from Git (.gitignore) and Docker
# builds (.dockerignore). This template is safe to commit — it contains
# no real secrets, only placeholder values that document what is required.
# =============================================================================

# --- CoinCap API -------------------------------------------------------------
# Obtain a free API key at: https://coincap.io/api-key
COINCAP_API_KEY=your_coincap_api_key_here

# --- MinIO Object Storage ----------------------------------------------------
# Root credentials for the MinIO server container (set at container startup).
MINIO_ROOT_USER=your_minio_admin_username
MINIO_ROOT_PASSWORD=your_strong_minio_password_here

# MinIO client settings used by boto3 and DuckDB httpfs inside Python scripts.
# In local development these match the root credentials above.
# In production, create a dedicated MinIO service account with least-privilege.
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=your_minio_admin_username
MINIO_SECRET_KEY=your_strong_minio_password_here
